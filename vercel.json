{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/dev",
      "dest": "/api/dev.php"
    },
    {
      "src": "/api/dev.php",
      "dest": "/api/dev.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
